# Local test server config — drives OMCSI for manual DPM testing.
#
# Copy this file to .env and edit values. The helper scripts (up.sh,
# reload-plugin.sh, down.sh, dpm-cmd.sh) source this file and pass the
# values to a sibling OMCSI checkout.

# Path to the OMCSI checkout. If missing, up.sh will clone it.
OMCSI_PATH=../omcsi

# OMCSI REST API base URL (exposed on the host by docker compose).
OMCSI_API_BASE=http://localhost:8092

# Bearer token guarding POST /api/plugins/deploy. Any non-empty string
# works for a local-only setup; use a strong random value if the host
# is shared.
DEPLOY_AUTH_TOKEN=local-dev-deploy-token

# RCON password and admin password for the OMCSI stack. Any non-empty
# values work locally.
RCON_PASSWORD=local-dev-rcon
ADMIN_PASSWORD=local-dev-admin

# Operator user for the Spigot server. Get your UUID at
# https://mcuuid.net/ if you want to log in and play.
OPERATOR_UUID=00000000-0000-0000-0000-000000000001
OPERATOR_NAME=LocalDev
OPERATOR_LEVEL=4

# Initial value for OMCSI's OVERWRITE_EXISTING_SERVER. up.sh writes this
# into ../omcsi/.env only on first run; after that, edit ../omcsi/.env
# directly to wipe the server's persistent data on the next start.
OVERWRITE_EXISTING_SERVER=false
